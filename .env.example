# Copy this file to .env and fill in your OpenAI API key
# Never commit .env
OPENAI_API_KEY=

# Optional: Gemini API key (used when "ai_provider": "gemini" in settings.json)
GEMINI_API_KEY=

# Optional: Deepgram API key (used when "ai_provider": "deepgram" in settings.json)
DEEPGRAM_API_KEY=

# Optional: Anthropic API key (used when "ai_provider": "claude" in settings.json)
ANTHROPIC_API_KEY=

# Optional: override default audio device index
# INPUT_DEVICE_INDEX=1
